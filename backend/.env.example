# ScoutVision AI — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── AI Report ──────────────────────────────────────────────
# Required for the AI Scouting Report feature.
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=

# ─── Data ───────────────────────────────────────────────────
# Path where StatsBomb event/match JSON data is stored.
# Default: ./data (the data/ folder inside the backend directory)
# STATSBOMB_DATA_DIR=./data

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend.
# Default: http://localhost:5173 (Vite dev server)
# CORS_ORIGINS=http://localhost:5173
